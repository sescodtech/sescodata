# ── Server ──────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/sescohub
JWT_SECRET=change-this-to-a-long-random-string

# ── Seed admin (server/seed.ts) ────────────────────────────
ADMIN_EMAIL=admin@sescohub.local
ADMIN_PASSWORD=ChangeMe123!

# ── Payments (Paystack) ─────────────────────────────────────
PAYSTACK_SECRET_KEY=

# ── Providers ───────────────────────────────────────────────
# Comma-separated failover order. Must match keys registered in
# ProviderOrchestrator (gladtidings, cheapdatahub, jarapoint).
PROVIDER_PRIORITY=gladtidings,cheapdatahub,jarapoint
JARAPOINT_API_KEY=
CHEAPDATAHUB_API_KEY=
GLADTIDINGS_API_KEY=

# ── Email (EmailService) ────────────────────────────────────
# Option A — SMTP (used first if EMAIL_USER + SMTP_HOST are set)
SMTP_HOST=
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@sescohub.com

# Option B — Resend HTTP API (used if SMTP isn't configured)
RESEND_API_KEY=

# Who receives contact/agent/support notifications
ADMIN_EMAIL=admin@sescohub.local

# Shown in email footers and the Support page
SUPPORT_EMAIL=support@sescohub.com
SUPPORT_PHONE=08140112803

# If neither SMTP nor Resend is configured, EmailService logs to the console
# instead of failing — the app stays fully functional without email set up.
